# Database (required for auth/admin features)
DATABASE_URL=postgresql://user:password@localhost:5432/safora

# NextAuth
NEXTAUTH_SECRET=replace-with-at-least-32-character-secret-key
NEXTAUTH_URL=http://localhost:3001

# Public site URL (used for JanaGana returnTo links)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# JanaGana CRM — class registration & events
NEXT_PUBLIC_JANAGANA_PORTAL_BASE_URL=https://janagana.namasteneedham.com
NEXT_PUBLIC_JANAGANA_API_URL=https://janagana.namasteneedham.com
NEXT_PUBLIC_JANAGANA_TENANT_SLUG=namaste-boston

# Optional: email, analytics, Sentry
# RESEND_API_KEY=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# SENTRY_DSN=
